MAIL_MAILER= # Ex: smtp
MAIL_HOST= # Ex: sandbox.smtp.mailtrap.io
MAIL_PORT= # Ex: 2525
MAIL_USERNAME= # Usuário do servidor SMTP
MAIL_PASSWORD= # Senha do servidor SMTP
MAIL_ENCRYPTION= # Ex: tls ou ssl
MAIL_FROM_ADDRESS= # Ex: no-reply@meusistema.com
MAIL_FROM_NAME= # Nome que aparecerá como remetente

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

AUTH_GUARD=api

L5_SWAGGER_CONST_HOST=http://localhost:8000/api

