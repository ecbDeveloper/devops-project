                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Id do Memorando",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/DespachoCadastrarValidation"
                            }
                        }
                    }
                },
                "responses": {
