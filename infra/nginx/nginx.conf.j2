server {
   listen 80;

    server_name _;

    location /api-wegia/ {
        proxy_pass {{ base_url_api_wegia }}{{ base_url_api_wegia_path }};
        proxy_set_header Host "api.wegia.local";
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_cache_bypass 1;
    }

    location /api/upload/ {
        proxy_pass {{ base_url_api_wegia }}/api/upload/;
        proxy_set_header Host "api.wegia.local";
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_cache_bypass 1;
    }

    location /api-pagar-me/ {
        proxy_pass {{ base_url_api_pagar_me }};
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_cache_bypass 1;
    }

    location / {
        proxy_pass http://localhost:3000;
        proxy_set_header Host $host;
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_cache_bypass 1;
    }
}
